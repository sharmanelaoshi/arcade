<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pickleball Mini Game</title>
<style>
  body { text-align: center; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #2c3e50; color: white; margin: 0; overflow: hidden; }
  
  /* Intro & Overlay Styles */
  #intro, #game-over {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(44, 62, 80, 0.95); z-index: 10;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  
  .char-select { display: flex; gap: 20px; margin: 20px; }
  .char-box { 
    padding: 15px; border: 3px solid #fff; border-radius: 10px; cursor: pointer; 
    transition: 0.3s; background: #34495e; 
  }
  .char-box:hover { transform: scale(1.1); background: #3b5fe2; }
  .char-box.selected { border-color: #f1c40f; background: #3b5fe2; }
  .char-icon { font-size: 50px; display: block; }

  canvas { background: #6bbf59; border: 6px solid #ecf0f1; border-radius: 10px; cursor: grab; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
  canvas:active { cursor: grabbing; }
  
  .score { font-size: 32px; margin: 10px; font-weight: bold; color: #f1c40f; }
  button { padding: 12px 24px; font-size: 18px; cursor: pointer; border-radius: 8px; border: none; background: #e67e22; color: white; font-weight: bold; }
  button:hover { background: #d35400; }
  
  .hidden { display: none !important; }
  .red-flash { animation: flash 0.3s; }
  @keyframes flash { 0% { background: #c0392b; } 100% { background: #6bbf59; } }
</style>
</head>
<body>

<div id="intro">
  <h1>🏓 Pro Pickleball Mini-Game</h1>
  <p>First to 5 wins! Choose your players:</p>
  
  <div style="display:flex; gap: 50px;">
    <div>
      <h3>Player 1</h3>
      <div class="char-select" id="p1-select">
        <div class="char-box selected" onclick="selectChar(1, '🦁')"><span class="char-icon">🦁</span></div>
        <div class="char-box" onclick="selectChar(1, '🤖')"><span class="char-icon">🤖</span></div>
      </div>
    </div>
    <div>
      <h3>Player 2</h3>
      <div class="char-select" id="p2-select">
        <div class="char-box" onclick="selectChar(2, '🦊')"><span class="char-icon">🦊</span></div>
        <div class="char-box selected" onclick="selectChar(2, '👽')"><span class="char-icon">👽</span></div>
      </div>
    </div>
  </div>
  
  <button onclick="startGame()">START MATCH</button>
</div>

<div id="game-over" class="hidden">
  <h1 id="winner-text">Player 1 Wins! 🎉</h1>
  <button onclick="restartGame()">PLAY AGAIN</button>
</div>

<h2>Pickleball Classroom Match</h2>
<div class="score">
  <span id="p1-name">🦁</span>: <span id="p1-score">0</span> 
  | 
  <span id="p2-name">👽</span>: <span id="p2-score">0</span>
</div>

<canvas id="game" width="800" height="400"></canvas>
<br>
<button onclick="toggleSound()" id="soundBtn">🔊 Sound ON</button>

<script>
const canvas = document.getElementById('game');
const ctx = canvas.getContext('2d');

let gameRunning = false;
let ball = { x: 400, y: 200, dx: 5, dy: 3, radius: 10 };
let p1 = { x: 30, y: 160, w: 15, h: 80, char: '🦁' };
let p2 = { x: 755, y: 160, w: 15, h: 80, char: '👽' };
let p1Score = 0;
let p2Score = 0;

// SOUND
let soundOn = true;
let audioCtx;
function playSfx(freq, type = 'square') {
  if (!soundOn) return;
  if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.connect(gain); gain.connect(audioCtx.destination);
  osc.frequency.value = freq;
  osc.type = type;
  osc.start();
  gain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.2);
  osc.stop(audioCtx.currentTime + 0.2);
}

function toggleSound() {
  soundOn = !soundOn;
  document.getElementById('soundBtn').textContent = soundOn ? '🔊 Sound ON' : '🔇 Sound OFF';
}

// INTRO LOGIC
function selectChar(player, icon) {
  const container = document.getElementById(`p${player}-select`);
  const boxes = container.getElementsByClassName('char-box');
  for (let box of boxes) box.classList.remove('selected');
  event.currentTarget.classList.add('selected');
  
  if (player === 1) {
    p1.char = icon;
    document.getElementById('p1-name').textContent = icon;
  } else {
    p2.char = icon;
    document.getElementById('p2-name').textContent = icon;
  }
}

function startGame() {
  document.getElementById('intro').classList.add('hidden');
  gameRunning = true;
  resetBall();
}

// CONTROLS (Dragging)
let dragging = null;
canvas.addEventListener('mousedown', (e) => {
  const rect = canvas.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  if (x > p1.x - 20 && x < p1.x + p1.w + 20) dragging = p1;
  if (x > p2.x - 20 && x < p2.x + p2.w + 20) dragging = p2;
});
canvas.addEventListener('mousemove', (e) => {
  if (!dragging) return;
  const rect = canvas.getBoundingClientRect();
  dragging.y = (e.clientY - rect.top) - dragging.h / 2;
  // Keep in bounds
  if (dragging.y < 10) dragging.y = 10;
  if (dragging.y > canvas.height - dragging.h - 10) dragging.y = canvas.height - dragging.h - 10;
});
canvas.addEventListener('mouseup', () => dragging = null);

function drawCourt() {
  ctx.fillStyle = '#6bbf59';
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.strokeStyle = '#ffffff';
  ctx.lineWidth = 3;
  ctx.strokeRect(10, 10, canvas.width-20, canvas.height-20);
  
  // Kitchen/Net lines
  ctx.beginPath();
  ctx.moveTo(canvas.width/2, 10); ctx.lineTo(canvas.width/2, canvas.height-10);
  ctx.moveTo(canvas.width/2 - 100, 10); ctx.lineTo(canvas.width/2 - 100, canvas.height-10);
  ctx.moveTo(canvas.width/2 + 100, 10); ctx.lineTo(canvas.width/2 + 100, canvas.height-10);
  ctx.stroke();
}

function drawPaddles() {
  ctx.font = "30px Arial";
  // P1
  ctx.fillStyle = '#3498db';
  ctx.fillRect(p1.x, p1.y, p1.w, p1.h);
  ctx.fillText(p1.char, p1.x - 35, p1.y + p1.h/2 + 10);
  // P2
  ctx.fillStyle = '#e74c3c';
  ctx.fillRect(p2.x, p2.y, p2.w, p2.h);
  ctx.fillText(p2.char, p2.x + 25, p2.y + p2.h/2 + 10);
}

function drawBall() {
  // Neon Pickleball Effect
  ctx.beginPath();
  ctx.arc(ball.x, ball.y, ball.radius, 0, Math.PI*2);
  ctx.fillStyle = '#ccff00'; // Neon Yellow
  ctx.shadowBlur = 10;
  ctx.shadowColor = '#ccff00';
  ctx.fill();
  ctx.shadowBlur = 0; // Reset shadow for other drawings
  
  // Pickleball holes
  ctx.fillStyle = 'rgba(0,0,0,0.2)';
  for(let i=0; i<4; i++) {
    ctx.beginPath();
    ctx.arc(ball.x + (i-1.5)*4, ball.y, 2, 0, Math.PI*2);
    ctx.fill();
  }
}

function updateBall() {
  if (!gameRunning) return;

  ball.x += ball.dx;
  ball.y += ball.dy;

  // Bounce Top/Bottom
  if (ball.y < 20 || ball.y > canvas.height-20) {
    ball.dy *= -1;
    playSfx(400, 'sine');
  }

  // Paddle Hits
  if (ball.x < p1.x + p1.w && ball.y > p1.y && ball.y < p1.y + p1.h) {
    ball.dx = Math.abs(ball.dx) * 1.05; // Speed up
    playSfx(600);
  }
  if (ball.x > p2.x - ball.radius && ball.y > p2.y && ball.y < p2.y + p2.h) {
    ball.dx = -Math.abs(ball.dx) * 1.05;
    playSfx(600);
  }

  // Score Logic
  if (ball.x < 0) {
    p2Score++;
    triggerFlash();
    checkGameOver();
    resetBall();
  } else if (ball.x > canvas.width) {
    p1Score++;
    triggerFlash();
    checkGameOver();
    resetBall();
  }

  document.getElementById('p1-score').textContent = p1Score;
  document.getElementById('p2-score').textContent = p2Score;
}

function triggerFlash() {
  canvas.classList.add('red-flash');
  playSfx(150, 'sawtooth');
  setTimeout(() => canvas.classList.remove('red-flash'), 300);
}

function resetBall() {
  ball.x = 400; ball.y = 200;
  ball.dx = (p1Score > p2Score ? -5 : 5);
  ball.dy = (Math.random() - 0.5) * 6;
}

function checkGameOver() {
  if (p1Score >= 5 || p2Score >= 5) {
    gameRunning = false;
    document.getElementById('game-over').classList.remove('hidden');
    document.getElementById('winner-text').textContent = 
      (p1Score >= 5 ? p1.char + ' Player 1' : p2.char + ' Player 2') + ' Wins! 🏆';
    playSfx(800);
  }
}

function restartGame() {
  p1Score = 0; p2Score = 0;
  document.getElementById('game-over').classList.add('hidden');
  document.getElementById('intro').classList.remove('hidden');
}

function gameLoop() {
  drawCourt();
  drawPaddles();
  drawBall();
  updateBall();
  requestAnimationFrame(gameLoop);
}

gameLoop();
</script>

</body>
</html>
